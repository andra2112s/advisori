# ═══════════════════════════════════════════
# Advisori — Environment Variables
# Copy ke .env dan isi semua value
# ═══════════════════════════════════════════

# ── Core ────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET=ganti-dengan-random-string-panjang-minimal-64-karakter

# ── Supabase ─────────────────────────────────
# Dapat dari: supabase.com → project → settings → API
SUPABASE_URL=https://almoejkachpjbtrmbvwh.supabase.co
SUPABASE_ANON_KEY=e   
SUPABASE_SERVICE_KEY=e 

# ── Anthropic ─────────────────────────────────
# Dapat dari: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Frontend ─────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Telegram Bot ─────────────────────────────
# Dapat dari: @BotFather di Telegram
# Ketik /newbot → ikuti instruksi → dapat token
TELEGRAM_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── WhatsApp ──────────────────────────────────
# Set true untuk enable WhatsApp bot
# Akan scan QR code saat pertama start
WHATSAPP_ENABLED=false

# ── Payment (Midtrans) ────────────────────────
# Dapat dari: dashboard.midtrans.com → settings → access keys
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_ENV=sandbox   # sandbox | production
