{
  "name": "advisori",
  "version": "2.0.0",
  "description": "Advisori — AI Personal Platform",
  "type": "module",
  "scripts": {
    "dev":         "node --watch backend/server.js",
    "dev:bot":     "node --watch bot/index.js",
    "dev:web":     "vite --port 3000",
    "dev:all":     "concurrently \"npm run dev\" \"npm run dev:bot\"",
    "start":       "node backend/server.js",
    "start:bot":   "node bot/index.js",
    "build":       "vite build",
    "preview":     "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk":         "^0.52.0",
    "@fastify/cors":             "^8.5.0",
    "@fastify/jwt":              "^8.0.1",
    "@fastify/rate-limit":       "^9.1.0",
    "@supabase/supabase-js":     "^2.45.0",
    "@whiskeysockets/baileys":   "^6.7.0",
    "bcryptjs":                  "^2.4.3",
    "concurrently":              "^9.0.0",
    "dotenv":                    "^16.4.0",
    "fastify":                   "^4.28.0",
    "node-cron":                 "^3.0.3",
    "node-fetch":                "^3.3.2",
    "node-telegram-bot-api":     "^0.66.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react":      "^4.3.0",
    "react":                     "^18.3.0",
    "react-dom":                 "^18.3.0",
    "react-router-dom":          "^6.26.0",
    "vite":                      "^5.4.0"
  },
  "engines": {
    "node": ">=22"
  }
}
